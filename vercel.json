{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/test",
            "destination": "/api/test"
        },
        {
            "source": "/api/health",
            "destination": "/api/index"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "/public/uploads/$1"
        },
        {
            "source": "/(.*)",
            "destination": "index.html"
        }
    ]
}
