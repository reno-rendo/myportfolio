# ================================
# GitHub OAuth (Required for Admin Login)
# Create app at: https://github.com/settings/developers
# ================================
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:5173/api/auth/github/callback

# Comma-separated GitHub usernames allowed to access admin
ALLOWED_ADMIN_USERNAMES=reno-rendo

# Environment
NODE_ENV=development

# ================================
# Database: SQLite Local (No setup needed!)
# File: sqlite.db (auto-created in project root)
# ================================
# Turso tidak diperlukan lagi - database lokal sudah aktif
