# ================================
# Admin Login (Manual - tidak perlu GitHub OAuth)
# Default: admin / admin123
# ================================

# Environment
NODE_ENV=development

# ================================
# Database: SQLite Local (No setup needed!)
# File: sqlite.db (auto-created in project root)
# ================================

# ================================
# Cloudflare Turnstile (Anti-spam for Contact Form)
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
# ================================
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
